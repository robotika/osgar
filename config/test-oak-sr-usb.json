{
  "version": 2,
  "robot": {
    "modules": {
      "oak": {
          "driver": "osgar.drivers.oak_camera:OakCamera",
          "init": {
            "cam_id": "1.1",
            "fps": 30,
            "subsample": null,
            "is_depth": true,
            "is_stereo_images": true,
            "is_imu_enabled": true,
            "mono_resolution": [1280, 800],
            "stereo_manual_exposure": [5000, 400],
            "stereo_manual_wb": 3000,

            "stereo_median_filter": "KERNEL_3x3",
            "depth_profile": "ROBOTICS",
            "stereo_extended_disparity": false,
            "stereo_subpixel": false,
            "stereo_left_right_check": true
          }
      }
    },
    "links": []
  }
}
