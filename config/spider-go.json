{
  "version": 2,
  "robot": {
    "modules": {

      "app": {
          "driver": "osgar.go:Go",
          "in": ["pose2d"],
          "out": ["desired_speed"],
          "init": {
            "max_speed": 0.3,
            "dist": 1.0,
            "timeout": 60
          }
      },

      "spider": {
          "driver": "spider",
          "in": ["can", "desired_speed"],
          "out": ["can"],
          "init": {}
      },
      "can": {
          "driver": "can",
          "in": ["raw", "can"],
          "out": ["can", "raw"],
          "init": {}
      },
      "serial": {
          "driver": "serial",
          "in": ["raw"],
          "out": ["raw"],
          "init": {"port": "/dev/ttyS0", "speed": 115200,
                   "rtscts":true, "reset":true}
      }

    },
    "links": [
              ["app.desired_speed", "spider.desired_speed"],
              ["spider.pose2d", "app.pose2d"],

              ["spider.can", "can.can"],
              ["can.can", "spider.can"],
              ["serial.raw", "can.raw"],
              ["can.raw", "serial.raw"]
    ]
  }
}
